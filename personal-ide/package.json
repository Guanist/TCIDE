{
  "name": "tcide",
  "productName": "TCIDE",
  "version": "1.0.0",
  "description": "虎猫 - 个人专属超级AI编程IDE",
  "main": "dist/main/index.js",
  "author": "Guanist, Inc.",
  "license": "MIT",
  "scripts": {
    "dev": "concurrently \"npm run dev:main\" \"npm run dev:renderer\"",
    "dev:main": "tsc -p tsconfig.main.json --watch",
    "dev:renderer": "vite",
    "build": "npm run build:main && npm run build:renderer",
    "build:main": "tsc -p tsconfig.main.json",
    "build:renderer": "vite build",
    "start": "electron .",
    "dist": "npm run build && electron-builder --win --config electron-builder.json",
    "build-exe": "npm run build && electron-builder --win --config electron-builder.json"
  },
  "dependencies": {
    "electron-store": "^8.2.0",
    "monaco-editor": "^0.52.2",
    "sql.js": "^1.14.1",
    "xterm": "^5.3.0",
    "xterm-addon-fit": "^0.8.0",
    "xterm-addon-web-links": "^0.9.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "concurrently": "^9.1.2",
    "electron": "^33.3.1",
    "electron-builder": "^25.1.8",
    "png-to-ico": "^3.0.1",
    "sharp": "^0.34.5",
    "typescript": "^5.7.3",
    "vite": "^6.0.7"
  }
}
